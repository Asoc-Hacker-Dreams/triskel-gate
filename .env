# Archivo de entorno local - NO COMMITEAR
NODE_ENV=development
PORT=3001

# Base de datos
DATABASE_PATH=./data/platform.db
DATABASE_KEY=triskelgate-dev-key-local

# Stripe (usar claves de test)
STRIPE_SECRET_KEY=sk_test_replace_with_your_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_test_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret

# JWT
JWT_SECRET=development-jwt-secret-not-for-production
JWT_EXPIRES_IN=24h

# Admin por defecto
ADMIN_EMAIL=admin@triskelgate.local
ADMIN_PASSWORD=admin123

# Email (configurar con tus credenciales)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=triskelgate Dev <dev@triskelgate.local>

# URLs locales
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
MAIN_APP_URL=http://localhost:5173
SUCCESS_URL=http://localhost:5173/checkout/success
CANCEL_URL=http://localhost:5173/checkout/failure

# Desarrollo
DEV_CONSOLE_LOGS=true
LOG_LEVEL=debug
