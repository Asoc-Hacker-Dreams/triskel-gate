# ==================================================
# triskelgate PAYMENT PLATFORM - CONFIGURACIÓN DE ENTORNO
# ==================================================

# Configuración del servidor
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# URLs permitidas para CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://triskelgate.com

# Base de datos Postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/triskell_gate
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000

# Stripe configuración
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# JWT configuración (Legacy — kept for backward compatibility during migration)
JWT_SECRET=super-secure-jwt-secret-change-in-production
JWT_EXPIRES_IN=24h
JWT_ALGORITHM=HS256

# Supabase Auth (Federated Login — replaces legacy JWT for new users)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Administrador por defecto (Legacy — will be deprecated with Supabase Auth)
ADMIN_EMAIL=admin@triskelgate.com
ADMIN_PASSWORD=triskelgate2025!Admin

# Configuración de email (NodeMailer)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=triskelgate Conference <noreply@triskelgate.com>

# Configuración de QR
QR_SECRET=triskelgate-qr-secret-2025-change-in-production

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
VALIDATION_RATE_LIMIT_MAX=20
SEARCH_RATE_LIMIT_MAX=50

# Configuración de archivos
UPLOAD_MAX_SIZE=10mb
PDF_STORAGE_PATH=./data/pdfs
TEMP_FILES_PATH=./data/temp

# URLs de la aplicación principal
MAIN_APP_URL=http://localhost:5173
SUCCESS_URL=http://localhost:5173/checkout/success
CANCEL_URL=http://localhost:5173/checkout/failure

# Configuración de seguridad
BCRYPT_ROUNDS=12
SESSION_SECRET=triskelgate-session-secret-change-in-production

# Configuración de logs
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# Redis (opcional, para sesiones distribuidas)
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=triskelgate:

# Health check
HEALTH_CHECK_TIMEOUT=5000

# Configuración de desarrollo
DEV_AUTO_LOGIN=false
DEV_MOCK_STRIPE=false
DEV_CONSOLE_LOGS=true

# Modo prueba para validar integración sin bloquear por fechas históricas
PAYMENT_TEST_MODE=true
SKIP_SALE_WINDOW_CHECK=true

# Configuración de producción
PRODUCTION_DOMAIN=api.triskelgate.com
SSL_CERT_PATH=/etc/ssl/certs/triskelgate.crt
SSL_KEY_PATH=/etc/ssl/private/triskelgate.key

# Monitoreo y métricas
SENTRY_DSN=your-sentry-dsn-here
ANALYTICS_ID=your-analytics-id-here

# Backup automático
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=6
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=./backups
