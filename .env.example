# ==================================================
# HACKBCN PAYMENT PLATFORM - CONFIGURACIÓN DE ENTORNO
# ==================================================

# Configuración del servidor
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# URLs permitidas para CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://hackbcn.com

# Base de datos SQLite
DATABASE_PATH=./data/platform.db
DATABASE_KEY=hackbcn-secure-key-2025-change-in-production

# Stripe configuración
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# JWT configuración
JWT_SECRET=super-secure-jwt-secret-change-in-production
JWT_EXPIRES_IN=24h
JWT_ALGORITHM=HS256

# Administrador por defecto
ADMIN_EMAIL=admin@hackbcn.com
ADMIN_PASSWORD=HackBCN2025!Admin

# Configuración de email (NodeMailer)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=HackBCN Conference <noreply@hackbcn.com>

# Configuración de QR
QR_SECRET=hackbcn-qr-secret-2025-change-in-production

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
VALIDATION_RATE_LIMIT_MAX=20
SEARCH_RATE_LIMIT_MAX=50

# Configuración de archivos
UPLOAD_MAX_SIZE=10mb
PDF_STORAGE_PATH=./data/pdfs
TEMP_FILES_PATH=./data/temp

# URLs de la aplicación principal
MAIN_APP_URL=http://localhost:5173
SUCCESS_URL=http://localhost:5173/checkout/success
CANCEL_URL=http://localhost:5173/checkout/failure

# Configuración de seguridad
BCRYPT_ROUNDS=12
SESSION_SECRET=hackbcn-session-secret-change-in-production

# Configuración de logs
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# Redis (opcional, para sesiones distribuidas)
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=hackbcn:

# Health check
HEALTH_CHECK_TIMEOUT=5000

# Configuración de desarrollo
DEV_AUTO_LOGIN=false
DEV_MOCK_STRIPE=false
DEV_CONSOLE_LOGS=true

# Configuración de producción
PRODUCTION_DOMAIN=api.hackbcn.com
SSL_CERT_PATH=/etc/ssl/certs/hackbcn.crt
SSL_KEY_PATH=/etc/ssl/private/hackbcn.key

# Monitoreo y métricas
SENTRY_DSN=your-sentry-dsn-here
ANALYTICS_ID=your-analytics-id-here

# Backup automático
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=6
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=./backups
