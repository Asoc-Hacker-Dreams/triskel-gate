{
  "name": "triskelgate-payment-platform",
  "version": "1.0.0",
  "description": "Plataforma de pago separada para TriskelGate - Superior a Eventbrite",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage",
    "test:integration": "cross-env NODE_ENV=test jest --testPathPattern=integration",
    "test:unit": "cross-env NODE_ENV=test jest --testPathIgnorePatterns=integration",
    "test:ci": "cross-env NODE_ENV=test jest --coverage --watchAll=false --passWithNoTests",
    "build": "echo 'Build completed - Node.js app ready'",
    "db:migrate": "drizzle-kit push:sqlite",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:seed": "node scripts/seed.js",
    "test:tickets": "node scripts/create-test-tickets.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "health": "curl -f http://localhost:3001/health || exit 1",
    "pretest": "npm run lint",
    "validate": "npm run lint && npm run test:ci",
    "build:docker": "docker build -t triskelgate-platform .",
    "build:docker:prod": "docker build --target production -t triskelgate-platform:prod .",
    "azure:setup": "./scripts/setup-azure-infrastructure.sh",
    "azure:deploy:staging": "echo 'Deploy to staging via Azure DevOps pipeline'",
    "azure:deploy:prod": "echo 'Deploy to production via Azure DevOps pipeline'",
    "azure:cleanup": "./scripts/cleanup-azure-infrastructure.sh",
    "azure:cleanup:dry-run": "./scripts/cleanup-azure-infrastructure.sh --dry-run",
    "azure:cleanup:delete": "./scripts/cleanup-azure-infrastructure.sh --delete",
    "osdo:all": "./.osdo/osdo.sh all",
    "osdo:sast": "./.osdo/osdo.sh sast",
    "osdo:sca": "./.osdo/osdo.sh sca",
    "osdo:container": "./.osdo/osdo.sh container",
    "osdo:buildah": "./.osdo/osdo.sh buildah",
    "osdo:gates": "./.osdo/osdo.sh gates",
    "osdo:report": "./.osdo/osdo.sh report",
    "osdo:status": "./.osdo/osdo.sh status",
    "osdo:clean": "./.osdo/osdo.sh clean",
    "buildah:build": "./.osdo/tools/buildah-builder.sh build",
    "buildah:build:dev": "./.osdo/tools/buildah-builder.sh build dev",
    "buildah:build:prod": "./.osdo/tools/buildah-builder.sh build prod",
    "security:sast": "./.osdo/tools/sast.sh",
    "security:sca": "./.osdo/tools/sca.sh",
    "security:container": "./.osdo/tools/container-scan.sh",
    "osdo:test:container": "./scripts/test-osdo-container-process.sh"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.2.2",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.29.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.3",
    "sharp": "^0.33.1",
    "sqlite3": "^5.1.6",
    "stripe": "^14.12.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.27.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.6",
    "babel-jest": "^30.0.0",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.20.18",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.1.1",
    "supertest": "^6.3.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
